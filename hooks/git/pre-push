#!/usr/bin/env node
// pre-push — GIT-NATIVE hook (universal). Blocks DIRECT pushes to main/master,
// while explicitly ALLOWING tag pushes and feature-branch pushes.
//
// This is the fix for the release/branch-guard conflict: the release flow does
//   git push origin <feature-branch> && git push origin v1.3.0
// Both are allowed here (tags always pass); only `git push origin main` is blocked,
// because main should advance via merged PRs, not direct pushes.
//
// Git invokes:  pre-push <remote-name> <remote-url>
// and streams, per ref, on stdin:  <local-ref> <local-oid> <remote-ref> <remote-oid>
//
// Escape hatch (intentional maintainer push to main): HARNESS_ALLOW_MAIN=1.
// Exit 0 = accept, exit 1 = reject. Internal error → exit 0.

const PROTECTED_REFS = new Set(["refs/heads/main", "refs/heads/master"]);

function readStdin() {
  return new Promise((resolve) => {
    let data = "";
    process.stdin.setEncoding("utf8");
    process.stdin.on("data", (c) => (data += c));
    process.stdin.on("end", () => resolve(data));
    // pre-push may receive no stdin in some setups; don't hang forever.
    setTimeout(() => resolve(data), 500);
  });
}

// Tolerant of Windows `set VAR=1 & cmd` (yields "1 " with a trailing space) and of
// 1/true/yes/on in any case — so the escape hatch is not a footgun.
function envAllow(name) {
  return ["1", "true", "yes", "on"].includes(String(process.env[name] || "").trim().toLowerCase());
}

(async () => {
  if (envAllow("HARNESS_ALLOW_MAIN")) process.exit(0);

  let raw = "";
  try {
    raw = await readStdin();
  } catch {
    process.exit(0);
  }

  const blocked = [];
  for (const line of raw.split(/\r?\n/)) {
    const parts = line.trim().split(/\s+/);
    if (parts.length < 4) continue;
    const remoteRef = parts[2]; // e.g. refs/heads/main, refs/tags/v1.3.0
    if (PROTECTED_REFS.has(remoteRef)) blocked.push(remoteRef);
  }

  if (blocked.length) {
    console.error(
      `🛑 pre-push (git-native): прямой push в ${blocked.join(", ")} запрещён.\n` +
        `   main/master должны продвигаться через merged PR, а не прямой push.\n` +
        `   Теги и feature-ветки пушить можно (это не блокируется).\n` +
        `   Намеренный push мейнтейнером:  HARNESS_ALLOW_MAIN=1 git push ...`
    );
    process.exit(1);
  }
  process.exit(0);
})();
