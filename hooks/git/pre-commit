#!/usr/bin/env node
// pre-commit — GIT-NATIVE hook (universal). Enforces AGENTS.md: коммиты в feature-ветку,
// не в main/master. Fires for any agent or human.
//
// Escape hatch for the RELEASE / HOTFIX flow (which legitimately commits on main,
// e.g. CHANGELOG bump):  set HARNESS_ALLOW_MAIN=1 for that single command.
//   HARNESS_ALLOW_MAIN=1 git commit -m "chore(release): v1.3.0"
//
// Exit 0 = accept, exit 1 = reject. Internal error / not-a-repo → exit 0.

const { execSync, spawnSync } = require("child_process");
const path = require("path");

const PROTECTED = new Set(["main", "master"]);

// Secret scan on staged content (BACKLOG P1-6). Blocks committing secrets. Fail-open
// if the scanner is missing or errors (secret-scan.js exits 1 only on a real finding).
function secretScan() {
  try {
    const scanner = path.join(__dirname, "..", "secret-scan.js");
    const r = spawnSync(process.execPath, [scanner, "--staged"], { stdio: "inherit" });
    return r.status === 1; // true = secrets found → block
  } catch { return false; }
}

function currentBranch() {
  // symbolic-ref works even on an unborn branch (before the first/root commit),
  // where `rev-parse --abbrev-ref HEAD` fails — so the root commit on main is caught too.
  for (const cmd of ["git symbolic-ref --short HEAD", "git rev-parse --abbrev-ref HEAD"]) {
    try {
      const b = execSync(cmd, { stdio: ["ignore", "pipe", "ignore"] }).toString().trim();
      if (b && b !== "HEAD") return b;
    } catch {}
  }
  return "";
}

// Tolerant of Windows `set VAR=1 & cmd` (yields "1 " with a trailing space) and of
// 1/true/yes/on in any case — so the escape hatch is not a footgun.
function envAllow(name) {
  return ["1", "true", "yes", "on"].includes(String(process.env[name] || "").trim().toLowerCase());
}

if (secretScan()) process.exit(1); // secrets in staged changes → block

const branch = currentBranch();
const allow = envAllow("HARNESS_ALLOW_MAIN");

if (PROTECTED.has(branch) && !allow) {
  console.error(
    `🛑 pre-commit (git-native): коммит на защищённой ветке «${branch}» запрещён.\n` +
      `   Создай feature-ветку:  git checkout -b feat/...  (или fix/..., docs/...)\n` +
      `   Релиз/hotfix, которому реально нужен коммит на ${branch}:\n` +
      `     HARNESS_ALLOW_MAIN=1 git commit ...   (или git commit --no-verify)`
  );
  process.exit(1);
}
process.exit(0);
