# Git hooks MUST use LF — a CRLF shebang (`#!/usr/bin/env node\r`) breaks execution
# on macOS/Linux ("node\r: not found"). Force LF regardless of platform / autocrlf.
hooks/git/commit-msg   text eol=lf
hooks/git/pre-commit   text eol=lf
hooks/git/pre-push     text eol=lf
hooks/**/*.js          text eol=lf
*.sh                   text eol=lf

# Default: normalize text, let git decide line endings on checkout for the rest.
* text=auto
