{
  "schemaVersion": 2,
  "_comment": "Universal harness capabilities. Project-owned: installer updates never replace this file.",
  "capabilities": {
    "ui": "auto",
    "release": "cocogitto",
    "serverPolicy": "github"
  },
  "ui": {
    "globs": [
      "**/*.ui",
      "**/*.qml",
      "**/*.slint",
      "**/*.xaml",
      "**/*.axaml",
      "**/*.razor",
      "**/*.cshtml",
      "**/*.tsx",
      "**/*.jsx",
      "**/*.vue",
      "**/*.svelte",
      "**/*.html",
      "**/*.css",
      "**/*.scss",
      "**/*.sass",
      "**/*.less",
      "**/res/layout/**/*.xml",
      "**/*View.swift",
      "**/ui/**",
      "**/views/**",
      "**/widgets/**",
      "**/components/**",
      "**/pages/**",
      "**/screens/**",
      "**/*_window.py",
      "**/*_dialog.py",
      "**/*_view.py",
      "**/*_widget.py"
    ],
    "exclude": [
      "**/node_modules/**",
      "**/vendor/**",
      "**/dist/**",
      "**/build/**",
      "**/bin/**",
      "**/obj/**",
      "**/coverage/**",
      "**/generated/**",
      "**/*.generated.*",
      "**/*.g.*",
      "**/*.test.*",
      "**/*.spec.*",
      "**/__tests__/**",
      "**/test/**",
      "**/tests/**",
      "**/fixtures/**"
    ],
    "mockups": {
      "dir": "design/mockups",
      "min": 4,
      "mockupExtensions": [".html", ".svg", ".png", ".jpg", ".jpeg", ".webp", ".pdf"],
      "manifestFile": "DESIGN.json",
      "approvalFile": "APPROVED"
    }
  },
  "_debugAudit_note": "verify.js scans only changed diff files for leftover debug statements. Hard markers fail VERIFY; soft markers are notes when soft=true. exclude contains globs skipped by the audit.",
  "debugAudit": {
    "enabled": true,
    "base": "main",
    "soft": false,
    "exclude": [],
    "strict": true
  },
  "release": {
    "provider": "cocogitto",
    "sourceZip": true,
    "artifacts": ["source-zip", "sha256"]
  },
  "serverPolicy": {
    "provider": "github",
    "profile": "solo"
  },
  "_verify_note": "Omit verify.stacks to enable auto-detect (python/dotnet/rust/node). Here we pin the harness's own self-test as the VERIFY step.",
  "verify": {
    "failFast": true,
    "stacks": [
      {
        "id": "harness",
        "markers": ["test.js"],
        "steps": [
          { "name": "self-test", "run": "node test.js" }
        ]
      }
    ]
  }
}
