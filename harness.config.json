{
  "_comment": "Configuration for the DESIGN-gate (BACKLOG P1-5). Adjust globs/min for your stack.",
  "ui": {
    "globs": [
      "**/*.ui",
      "**/*.qml",
      "**/*.slint",
      "**/ui/**",
      "**/views/**",
      "**/widgets/**",
      "**/*_window.py",
      "**/*_dialog.py",
      "**/*_view.py",
      "**/*_widget.py"
    ],
    "mockups": {
      "dir": "design/mockups",
      "min": 4,
      "mockupExtensions": [".html", ".svg", ".png", ".jpg", ".jpeg", ".webp", ".pdf"],
      "approvalFile": "APPROVED"
    }
  },
  "_verify_note": "Omit verify.stacks to enable auto-detect (python/dotnet/rust/node). Here we pin the harness's own self-test as the VERIFY step.",
  "verify": {
    "failFast": true,
    "stacks": [
      {
        "id": "harness",
        "markers": ["test.js"],
        "steps": [
          { "name": "self-test", "run": "node test.js" }
        ]
      }
    ]
  }
}
